{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {

    "nostr": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@nostrbook/mcp@latest"
      ],
      "enabled": true,
      "timeout": 30000
    },

    "pencil_desktop": {
      "type": "local",
      "command": [
        "/opt/pencil-dev-bin/resources/app.asar.unpacked/out/mcp-server-linux-x64",
        "--app",
        "desktop"
      ],
      "enabled": true
    }
  }
}